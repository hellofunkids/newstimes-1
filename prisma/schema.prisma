generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ChildProfile {
  id        String             @id @default(cuid())
  name      String
  level     Level
  avatar    String?
  attempts  RecordingAttempt[]
  createdAt DateTime           @default(now())
}

enum Level {
  ELEMENTARY
  MIDDLE
  JUNIOR
}

model Article {
  id             String             @id @default(cuid())
  level          Level
  category       String
  title          String
  script         String
  sourceHeadline String
  sourceUrl      String?
  publishedAt    DateTime           @default(now())
  attempts       RecordingAttempt[]
}

model RecordingAttempt {
  id             String       @id @default(cuid())
  childProfileId String
  childProfile   ChildProfile @relation(fields: [childProfileId], references: [id])
  articleId      String
  article        Article      @relation(fields: [articleId], references: [id])
  transcript     String
  accuracyScore  Int
  feedback       String?
  createdAt      DateTime     @default(now())
}
